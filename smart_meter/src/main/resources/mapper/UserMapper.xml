<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.purelearning.smart_meter.mapper.UserMapper">

    <select id="selectByOpenid" resultType="com.purelearning.smart_meter.entity.User">
        SELECT
            id,
            openid,
            nickname,
            avatar_url,
            status,
            user_type,
            create_time,
            update_time
        FROM users
        WHERE openid = #{openid}
        LIMIT 1
    </select>

</mapper>

