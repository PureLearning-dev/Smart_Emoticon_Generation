.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #F7F8FA;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.06);
}

.head-card .title {
  font-size: 36rpx;
  color: #333333;
  font-weight: 600;
}

.head-card .subtitle {
  margin-top: 8rpx;
  display: block;
  font-size: 24rpx;
  color: #666666;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.input-textarea {
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E9EDF3;
  background: #FFFFFF;
  font-size: 28rpx;
  color: #333333;
}

.placeholder {
  color: #999999;
  font-size: 24rpx;
}

.reference-area {
  margin-top: 8rpx;
}

.reference-add {
  height: 160rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #E9EDF3;
  background: #F7F8FA;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reference-add-text {
  font-size: 26rpx;
  color: #07C160;
}

.reference-preview {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.reference-thumb {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  display: block;
}

.reference-clear {
  position: absolute;
  right: 0;
  top: 0;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  color: #FFFFFF;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 8rpx;
}

.primary-btn {
  margin-top: 16rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #07C160;
  color: #FFFFFF;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.primary-btn[disabled] {
  background: #B3E5C2;
  color: #FFFFFF;
}

.secondary-btn {
  height: 80rpx;
  border-radius: 16rpx;
  border: 2rpx solid #07C160;
  color: #07C160;
  font-size: 28rpx;
  background: #FFFFFF;
}

.hint-card {
  text-align: center;
  padding: 32rpx;
}

.hint-text {
  font-size: 26rpx;
  color: #999999;
}

.result-card .section-head {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.result-image-wrap {
  width: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F7F8FA;
}

.result-image {
  width: 100%;
  display: block;
}

.result-meta {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #F0F2F5;
}

.result-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.result-row:last-child {
  margin-bottom: 0;
}

.result-label {
  font-size: 26rpx;
  color: #666666;
  width: 140rpx;
  flex-shrink: 0;
}

.result-value {
  font-size: 28rpx;
  color: #333333;
}

.result-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 20rpx;
}

.result-actions .primary-btn,
.result-actions .secondary-btn {
  flex: 1;
  margin-top: 0;
}

button::after {
  border: none;
}
