.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #f3fff8 0%, #f7f8fa 360rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card,
.hero-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(31, 35, 41, 0.06);
  box-sizing: border-box;
}

.hero-card {
  overflow: hidden;
  position: relative;
}

.hero-card::after {
  content: "";
  position: absolute;
  top: -90rpx;
  right: -80rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(7, 193, 96, 0.12);
}

.hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #07c160;
  font-weight: 600;
}

.title {
  display: block;
  margin-top: 8rpx;
  font-size: 40rpx;
  color: #222222;
  font-weight: 700;
  line-height: 1.3;
}

.hero-badge {
  position: relative;
  z-index: 1;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
}

.subtitle {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #666666;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-item-row .form-label {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.input-textarea {
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
  padding: 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid #edf1f5;
  background: #f7f8fa;
  font-size: 28rpx;
  color: #333333;
}

.placeholder {
  color: #b6bcc5;
  font-size: 26rpx;
}

.reference-area {
  margin-top: 8rpx;
}

.reference-add {
  height: 160rpx;
  border-radius: 20rpx;
  border: 2rpx dashed rgba(7, 193, 96, 0.28);
  background: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reference-add-text {
  font-size: 26rpx;
  color: #07c160;
  font-weight: 600;
}

.reference-preview {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.reference-thumb {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  display: block;
}

.reference-clear {
  position: absolute;
  right: 0;
  top: 0;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  color: #ffffff;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 8rpx;
}

.primary-btn {
  margin-top: 16rpx;
  height: 84rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #07c160, #31d983);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-shadow: 0 10rpx 22rpx rgba(7, 193, 96, 0.22);
}

.primary-btn[disabled] {
  background: #b3e5c2;
  color: #ffffff;
  box-shadow: none;
}

.secondary-btn {
  height: 80rpx;
  border-radius: 16rpx;
  border: 2rpx solid #07c160;
  color: #07c160;
  font-size: 28rpx;
  background: #ffffff;
}

.hint-card {
  text-align: center;
  padding: 32rpx;
}

.hint-text {
  font-size: 26rpx;
  color: #999999;
}

.result-card .section-head {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 700;
}

.result-image-wrap {
  width: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f7f8fa;
}

.result-image {
  width: 100%;
  display: block;
}

.result-meta {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f2f5;
}

.result-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.result-row:last-child {
  margin-bottom: 0;
}

.result-label {
  font-size: 26rpx;
  color: #666666;
  width: 140rpx;
  flex-shrink: 0;
}

.result-value {
  font-size: 28rpx;
  color: #333333;
}

.result-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 20rpx;
}

.result-actions .primary-btn,
.result-actions .secondary-btn {
  flex: 1;
  margin-top: 0;
}

button::after {
  border: none;
}
