<view class="page">
  <view class="card head-card">
    <text class="title">生成图片</text>
    <text class="subtitle">输入描述词，可选参考图，生成专属表情包</text>
  </view>

  <view class="card form-card">
    <view class="form-item">
      <text class="form-label">描述词（必填）</text>
      <textarea
        class="input-textarea"
        placeholder="请输入描述词，例如：一只搞笑的猫咪在敲键盘"
        placeholder-class="placeholder"
        value="{{prompt}}"
        bindinput="onInputPrompt"
        maxlength="500"
        show-confirm-bar="{{false}}"
      />
    </view>

    <view class="form-item">
      <text class="form-label">参考图（可选）</text>
      <view class="reference-area">
        <view wx:if="{{!referenceImagePath}}" class="reference-add" bindtap="onChooseReferenceImage">
          <text class="reference-add-text">+ 添加参考图</text>
        </view>
        <view wx:else class="reference-preview">
          <image class="reference-thumb" src="{{referenceImagePath}}" mode="aspectFill" />
          <view class="reference-clear" bindtap="onClearReferenceImage">清除</view>
        </view>
      </view>
    </view>

    <view class="form-item form-item-row">
      <text class="form-label">公开到广场</text>
      <switch checked="{{isPublic === 1}}" color="#07C160" bindchange="onSwitchPublic" />
    </view>

    <button
      class="primary-btn"
      disabled="{{loading}}"
      bindtap="onSubmit"
    >{{loading ? '生成中...' : '生成'}}</button>
  </view>

  <view wx:if="{{!result && !loading}}" class="card hint-card">
    <text class="hint-text">输入描述词并点击「生成」即可生成表情包</text>
  </view>

  <view wx:if="{{result}}" class="card result-card">
    <view class="section-head">
      <text class="section-title">生成结果</text>
    </view>
    <view class="result-image-wrap" bindtap="onPreviewImage">
      <image
        class="result-image"
        src="{{result.imageUrl}}"
        mode="widthFix"
      />
    </view>
    <view class="result-meta">
      <view class="result-row">
        <text class="result-label">使用场景</text>
        <text class="result-value">{{result.usageScenario}}</text>
      </view>
      <view class="result-row">
        <text class="result-label">分类</text>
        <text class="result-value">{{result.styleTag}}</text>
      </view>
    </view>
    <view class="result-actions">
      <button type="default" class="secondary-btn" bindtap="onGenerateAgain">再生成一次</button>
      <button type="primary" class="primary-btn" bindtap="goMyCreation">去我的生成</button>
    </view>
  </view>
</view>
