.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f7f8fa;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 48rpx 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.06);
  text-align: center;
}

.empty-card {
  margin-top: 80rpx;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999999;
}

.state-text {
  text-align: center;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: #999999;
}

.list-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.fav-card {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.06);
}

.fav-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.fav-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  justify-content: center;
}

.fav-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.fav-meta {
  font-size: 22rpx;
  color: #86909c;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fav-tag {
  align-self: flex-start;
  font-size: 20rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.12);
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
}

.load-more-wrap {
  padding: 24rpx 0 48rpx;
  text-align: center;
}

.load-more-btn {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
  font-size: 28rpx;
  border: none;
}

.load-hint {
  font-size: 26rpx;
  color: #999999;
}

button::after {
  border: none;
}
