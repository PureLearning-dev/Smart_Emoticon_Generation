<view class="page">
  <view wx:if="{{loading && !list.length}}" class="state-text">加载中...</view>

  <view wx:elif="{{!loading && !list.length}}" class="card empty-card">
    <text class="empty-icon">📋</text>
    <text class="empty-title">暂无收藏</text>
    <text class="empty-desc">在素材详情或我的生成详情中点击「收藏」</text>
  </view>

  <view wx:else class="list-wrap">
    <view
      class="fav-card"
      wx:for="{{list}}"
      wx:key="id"
      data-item="{{item}}"
      bindtap="onTapItem"
    >
      <image class="fav-thumb" src="{{item.imageUrl || 'https://dummyimage.com/400x400/f7f8fa/999999&text=+'}}" mode="aspectFill" />
      <view class="fav-body">
        <text class="fav-title">{{item.title || '未命名'}}</text>
        <text class="fav-meta">{{item.usageScenario || '日常'}} · {{item.styleTag || '日常'}}</text>
        <text class="fav-tag">{{item.targetType === 'GENERATED_IMAGE' ? '我的生成' : '素材库'}}</text>
      </view>
    </view>

    <view class="load-more-wrap">
      <button
        wx:if="{{hasMore && !loadingMore}}"
        class="load-more-btn"
        bindtap="onLoadMore"
      >加载更多</button>
      <text wx:elif="{{loadingMore}}" class="load-hint">加载中…</text>
      <text wx:elif="{{list.length && !hasMore}}" class="load-hint">没有更多了</text>
    </view>
  </view>
</view>
