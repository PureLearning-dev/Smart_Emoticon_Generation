.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f7f8fa;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.06);
}

.title {
  font-size: 36rpx;
  color: #333333;
  font-weight: 600;
}

.subtitle {
  margin-top: 8rpx;
  display: block;
  font-size: 24rpx;
  color: #666666;
}

.hero-card {
  padding-bottom: 24rpx;
}

.profile-shell {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 20rpx;
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: rgba(7, 193, 96, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.name {
  display: block;
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.helper {
  margin-top: 6rpx;
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.status-chip {
  font-size: 22rpx;
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.status-chip-online {
  color: #07c160;
  background: rgba(7, 193, 96, 0.12);
}

.status-chip-offline {
  color: #999999;
  background: #eef1f5;
}

.auth-actions {
  margin-top: 20rpx;
}

.primary-btn,
.danger-btn {
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.primary-btn {
  background: #07c160;
  color: #ffffff;
}

.danger-btn {
  background: rgba(238, 10, 36, 0.12);
  color: #ee0a24;
}

/* 功能列表卡片 */
.list-card {
  padding: 0 24rpx;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  min-height: 100rpx;
  box-sizing: border-box;
}

.list-item-hover {
  opacity: 0.85;
}

.list-item-left {
  flex: 1;
  min-width: 0;
}

.list-item-title {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}

.list-item-desc {
  margin-top: 6rpx;
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.list-item-arrow {
  font-size: 36rpx;
  color: #999999;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.list-divider {
  height: 2rpx;
  background: #f0f2f5;
  margin: 0;
}

.footer-text {
  margin-top: 16rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}

button::after {
  border: none;
}
