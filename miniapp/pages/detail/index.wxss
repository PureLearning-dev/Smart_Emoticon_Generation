.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f7f8fa;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.06);
}

.title {
  font-size: 36rpx;
  color: #333333;
  font-weight: 600;
}

.subtitle {
  display: block;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999999;
}

.cover {
  margin-top: 20rpx;
  width: 100%;
  height: 420rpx;
  border-radius: 16rpx;
  display: block;
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.text-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.helper {
  display: block;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.tag-row {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.article-tag {
  align-self: flex-start;
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.12);
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.6;
}

.primary-btn {
  margin-top: 20rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #07c160;
  color: #ffffff;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.ghost-btn {
  margin-top: 20rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.state-text {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}

button::after {
  border: none;
}
