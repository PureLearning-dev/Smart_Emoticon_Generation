.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f7f8fa;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.06);
}

.hero-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #ffffff 0%, #f3fff8 100%);
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 12rpx 36rpx rgba(7, 193, 96, 0.12);
}

.hero-glow {
  position: absolute;
  right: -90rpx;
  top: -90rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(7, 193, 96, 0.14);
}

.title-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: #07c160;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.title {
  display: block;
  font-size: 42rpx;
  color: #1f2329;
  font-weight: 700;
  line-height: 1.25;
}

.tag {
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #07c160;
  background: #ffffff;
  border: 2rpx solid rgba(7, 193, 96, 0.16);
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  box-shadow: 0 8rpx 18rpx rgba(7, 193, 96, 0.08);
}

.hero-slogan {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  display: block;
  font-size: 28rpx;
  color: #4e5969;
  line-height: 1.65;
}

.feature-row {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.feature-chip {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
}

.hero-metrics {
  position: relative;
  z-index: 1;
  margin-top: 28rpx;
  padding: 22rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(7, 193, 96, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.metric-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.metric-value {
  font-size: 26rpx;
  color: #1f2329;
  font-weight: 700;
}

.metric-label {
  font-size: 22rpx;
  color: #86909c;
}

.metric-divider {
  width: 2rpx;
  height: 48rpx;
  background: #edf1f5;
}

.tab-hint {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  display: block;
  font-size: 24rpx;
  color: #86909c;
  line-height: 1.6;
}

.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.section-desc {
  font-size: 24rpx;
  color: #999999;
}

.section-desc {
  color: #666666;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recommend-item {
  border: 2rpx solid #edf1f5;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recommend-item-hover {
  opacity: 0.9;
}

.recommend-cover {
  width: 100%;
  height: 280rpx;
  border-radius: 16rpx;
  display: block;
  background: #f2f4f7;
}

.recommend-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.recommend-title {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  line-height: 1.5;
}

.recommend-tag {
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.12);
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
}

.recommend-summary {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.recommend-action {
  height: 80rpx;
  border-radius: 16rpx;
  background: rgba(7, 193, 96, 0.1);
  color: #07c160;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.recommend-state {
  border: 2rpx solid #edf1f5;
  border-radius: 16rpx;
  background: #ffffff;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.recommend-state-text {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}

.recommend-retry-btn {
  width: 240rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
  font-size: 26rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.recommend-more {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 80rpx;
}

.recommend-more-btn {
  width: 240rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
  font-size: 26rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.recommend-more-loading {
  font-size: 26rpx;
  color: #999999;
}

.recommend-more-done {
  font-size: 24rpx;
  color: #999999;
}

button::after {
  border: none;
}
