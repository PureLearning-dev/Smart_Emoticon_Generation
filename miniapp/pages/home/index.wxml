<view class="page">
  <view class="page-header card">
    <view class="title-row">
      <text class="title">智能表情包中心</text>
      <text class="tag">Beta</text>
    </view>
    <text class="hero-slogan">发现与生成你的表情包</text>
    <text class="tab-hint">使用底部导航可切换到搜索、广场、生成与个人中心</text>
  </view>

  <view class="recommend-card card">
    <view class="section-head">
      <text class="section-title">推荐内容</text>
      <text class="section-desc">首页文章推荐</text>
    </view>

    <view wx:if="{{recommendLoading}}" class="recommend-state">推荐内容加载中...</view>

    <view wx:elif="{{recommendError}}" class="recommend-state">
      <text class="recommend-state-text">推荐内容加载失败，请稍后重试</text>
      <button type="default" class="recommend-retry-btn" bindtap="retryRecommendations">重新加载</button>
    </view>

    <view wx:elif="{{!recommendList.length}}" class="recommend-state">
      <text class="recommend-state-text">暂无推荐文章</text>
    </view>

    <view wx:else>
      <view class="recommend-list">
        <view
          class="recommend-item"
          wx:for="{{recommendList}}"
          wx:key="id"
          data-item="{{item}}"
          hover-class="recommend-item-hover"
          bindtap="onTapRecommend"
        >
          <image
            wx:if="{{item.coverUrl}}"
            class="recommend-cover"
            src="{{item.coverUrl}}"
            mode="aspectFill"
          />
          <view class="recommend-top">
            <text class="recommend-title">{{item.title}}</text>
            <text class="recommend-tag">{{item.tag}}</text>
          </view>
          <text class="recommend-summary">{{item.summary}}</text>
          <view class="recommend-action">{{item.actionText}}</view>
        </view>
      </view>
      <view class="recommend-more">
        <button
          wx:if="{{hasMore && !recommendLoadingMore}}"
          type="default"
          class="recommend-more-btn"
          bindtap="loadMoreRecommendations"
        >加载更多</button>
        <text wx:elif="{{recommendLoadingMore}}" class="recommend-more-loading">加载中…</text>
        <text wx:elif="{{!hasMore && recommendList.length}}" class="recommend-more-done">没有更多了</text>
      </view>
    </view>
  </view>
</view>
