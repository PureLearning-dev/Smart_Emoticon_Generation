.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f7f8fa;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.06);
}

.title {
  font-size: 36rpx;
  color: #333333;
  font-weight: 600;
}

.subtitle {
  margin-top: 20rpx;
  display: block;
  font-size: 30rpx;
  color: #666666;
}

.label {
  margin-top: 20rpx;
  display: block;
  font-size: 24rpx;
  color: #666666;
}

.input {
  margin-top: 20rpx;
  height: 80rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e9edf3;
  box-sizing: border-box;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.placeholder {
  color: #999999;
  font-size: 24rpx;
}

.primary-btn,
.ghost-btn {
  height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.primary-btn {
  background: #07c160;
  color: #ffffff;
}

.ghost-btn {
  margin-top: 20rpx;
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
}

button::after {
  border: none;
}
