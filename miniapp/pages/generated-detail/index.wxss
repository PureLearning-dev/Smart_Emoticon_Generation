.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f7f8fa;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.06);
}

.state-text {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999999;
}

.title {
  font-size: 34rpx;
  color: #333333;
  font-weight: 600;
}

.subtitle {
  margin-top: 12rpx;
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.cover {
  margin-top: 20rpx;
  width: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  display: block;
  background: #f0f0f0;
}

.section-head {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 2rpx solid #f0f2f5;
}

.meta-row:last-child {
  border-bottom: none;
}

.meta-label {
  font-size: 26rpx;
  color: #666666;
}

.meta-value {
  font-size: 26rpx;
  color: #333333;
  max-width: 420rpx;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag {
  font-size: 22rpx;
  color: #FE2C55;
  background: rgba(254, 44, 85, 0.1);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.text-content {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  word-break: break-all;
  white-space: normal;
  display: block;
}

.actions-card {
  display: flex;
  gap: 20rpx;
}

.primary-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  background: #07c160;
  color: #ffffff;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.share-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  background: rgba(254, 44, 85, 0.1);
  color: #FE2C55;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

button::after {
  border: none;
}

