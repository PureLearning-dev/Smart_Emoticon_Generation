.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #f3fff8 0%, #f7f8fa 360rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card,
.hero-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(31, 35, 41, 0.06);
  box-sizing: border-box;
}

.hero-card {
  position: relative;
  overflow: hidden;
}

.hero-card::after {
  content: "";
  position: absolute;
  top: -90rpx;
  right: -80rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(7, 193, 96, 0.12);
}

.hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #07c160;
  font-weight: 600;
}

.title {
  display: block;
  margin-top: 8rpx;
  font-size: 40rpx;
  color: #222222;
  font-weight: 700;
  line-height: 1.3;
}

.hero-badge {
  position: relative;
  z-index: 1;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
}

.subtitle {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #666666;
}

.search-panel {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.input-wrap {
  min-height: 92rpx;
  border-radius: 20rpx;
  border: 2rpx solid #edf1f5;
  background: #f7f8fa;
  padding: 14rpx 20rpx;
  box-sizing: border-box;
}

.input-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: #999999;
}

.input {
  width: 100%;
  height: 40rpx;
  font-size: 28rpx;
  color: #333333;
}

.placeholder {
  color: #b6bcc5;
  font-size: 26rpx;
}

.primary-btn {
  height: 84rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #07c160, #31d983);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-shadow: 0 10rpx 22rpx rgba(7, 193, 96, 0.22);
}

.list-card {
  flex: 1;
  min-height: 240rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  color: #333333;
  font-weight: 700;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999999;
}

.section-desc {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #666666;
  background: #f7f8fa;
}

.state-wrap {
  min-height: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  text-align: center;
}

.state-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #07c160;
  box-shadow: 0 0 0 12rpx rgba(7, 193, 96, 0.12);
}

.empty-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}

.state-text {
  max-width: 520rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #999999;
}

.state-error {
  color: #ee0a24;
}

.waterfall,
.waterfall-inner {
  width: 100%;
}

.waterfall-inner {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.plaza-card {
  width: calc(50% - 10rpx);
  border-radius: 20rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.08);
}

.card-image {
  width: 100%;
  display: block;
  background: #f0f0f0;
}

.card-body {
  padding: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.card-usage {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.card-style {
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-more {
  font-size: 22rpx;
  color: #999999;
}

button::after {
  border: none;
}
