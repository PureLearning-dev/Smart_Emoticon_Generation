<view class="page">
  <view class="card list-card">
    <text class="title">智能搜索</text>
    <text class="subtitle">文本搜图 / 图搜图 / URL 搜图</text>

    <view class="mode-row">
      <view
        class="mode-btn {{mode==='text' ? 'mode-btn-active' : ''}}"
        data-mode="text"
        bindtap="switchMode"
      >
        文本
      </view>
      <view
        class="mode-btn {{mode==='image' ? 'mode-btn-active' : ''}}"
        data-mode="image"
        bindtap="switchMode"
      >
        上传图片
      </view>
      <view
        class="mode-btn {{mode==='url' ? 'mode-btn-active' : ''}}"
        data-mode="url"
        bindtap="switchMode"
      >
        图片 URL
      </view>
    </view>

    <view wx:if="{{mode==='text'}}" class="search-panel">
      <input
        class="input"
        placeholder="请输入搜索关键词"
        placeholder-class="placeholder"
        value="{{keyword}}"
        bindinput="onInputKeyword"
      />
      <button class="primary-btn" bindtap="onSearchAction">开始搜索</button>
    </view>

    <view wx:if="{{mode==='url'}}" class="search-panel">
      <input
        class="input"
        placeholder="请输入图片 URL"
        placeholder-class="placeholder"
        value="{{imageUrl}}"
        bindinput="onInputImageUrl"
      />
      <button class="primary-btn" bindtap="onSearchAction">URL 搜图</button>
    </view>

    <view wx:if="{{mode==='image'}}" class="search-panel">
      <view class="upload-card">
        <text class="upload-tip">从相册/相机选择图片后自动搜索</text>
        <text wx:if="{{imagePath}}" class="helper">已选择：{{imagePath}}</text>
      </view>
      <button class="primary-btn" bindtap="onSearchAction">选择并搜索</button>
    </view>
  </view>

  <view class="card">
    <view class="section-head">
      <text class="section-title">搜索结果</text>
      <text class="section-desc">{{list.length}} 条</text>
    </view>

    <view wx:if="{{loading}}" class="state-text">加载中...</view>
    <view wx:elif="{{list.length===0}}" class="state-text">暂无结果，试试其他关键词</view>

    <view wx:else class="waterfall">
      <view class="waterfall-inner">
        <view
          class="plaza-card"
          wx:for="{{list}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="goDetail"
        >
          <image class="card-image" src="{{item.generatedImageUrl || 'https://dummyimage.com/800x480/f7f8fa/999999&text=No+Image'}}" mode="widthFix" />
          <view class="card-body">
            <text class="card-usage">{{item.usageScenario || '日常'}}</text>
            <text class="card-style">{{item.styleTag || '日常'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
