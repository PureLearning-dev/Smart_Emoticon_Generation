.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f7f8fa;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.06);
}

.title {
  font-size: 36rpx;
  color: #333333;
  font-weight: 600;
}

.subtitle {
  margin-top: 20rpx;
  display: block;
  font-size: 30rpx;
  color: #666666;
}

.mode-row {
  margin-top: 20rpx;
  display: flex;
  gap: 20rpx;
}

.mode-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666666;
  background: #f7f8fa;
  border-radius: 16rpx;
  height: 80rpx;
}

.mode-btn-active {
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
  font-weight: 600;
}

.search-panel {
  margin-top: 20rpx;
}

.input {
  height: 80rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e9edf3;
  background: #ffffff;
  box-sizing: border-box;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.placeholder {
  color: #999999;
  font-size: 24rpx;
}

.primary-btn {
  margin-top: 20rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #07c160;
  color: #ffffff;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.upload-card {
  border-radius: 16rpx;
  background: #f7f8fa;
  padding: 20rpx;
}

.upload-tip {
  display: block;
  font-size: 28rpx;
  color: #333333;
}

.helper {
  margin-top: 20rpx;
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.section-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.section-desc {
  font-size: 24rpx;
  color: #999999;
}

.state-text {
  margin-top: 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
}

.list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.list-item {
  border-radius: 16rpx;
  border: 2rpx solid #f0f2f5;
  background: #ffffff;
  padding: 20rpx;
}

.cover {
  width: 100%;
  height: 260rpx;
  border-radius: 16rpx;
  display: block;
}

.item-content {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item-title {
  font-size: 28rpx;
  color: #333333;
}

.item-text {
  font-size: 24rpx;
  color: #666666;
}

button::after {
  border: none;
}
