<view class="page">
  <view class="card head-card">
    <text class="title">素材库图搜图</text>
    <text class="subtitle">在爬虫/离线入库的素材库中按图片查找相似表情包</text>
    <view class="upload-panel">
      <view wx:if="{{!imagePath}}" class="choose-area" bindtap="chooseImage">
        <text class="choose-icon">🖼️</text>
        <text class="choose-tip">点击选择图片</text>
        <text class="choose-desc">从相册或相机选择</text>
      </view>
      <view wx:else class="preview-area">
        <image class="preview-img" src="{{imagePath}}" mode="aspectFill" />
        <button type="default" class="ghost-btn" bindtap="chooseImage">重新选择</button>
      </view>
      <button type="default" class="primary-btn" bindtap="onSearch">开始搜图</button>
    </view>
  </view>

  <view class="card result-card">
    <view class="section-head">
      <text class="section-title">搜索结果</text>
      <text class="section-desc" wx:if="{{hasSearched && !loading}}">{{list.length}} 条</text>
    </view>

    <view wx:if="{{loading}}" class="state-wrap">
      <text class="state-text">加载中...</text>
    </view>
    <view wx:elif="{{error}}" class="state-wrap">
      <text class="state-text state-error">加载失败，请重试</text>
    </view>
    <view wx:elif="{{hasSearched && list.length === 0}}" class="state-wrap">
      <text class="state-text">暂无结果，试试其他图片</text>
    </view>
    <view wx:elif="{{list.length > 0}}" class="waterfall">
      <view class="waterfall-inner">
        <view
          class="plaza-card"
          wx:for="{{list}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-file-url="{{item.generatedImageUrl}}"
          data-ocr-text="{{item.usageScenario}}"
          bindtap="goDetail"
        >
          <image
            class="card-image"
            src="{{item.generatedImageUrl || 'https://dummyimage.com/800x480/f7f8fa/999999&text=No+Image'}}"
            mode="widthFix"
          />
          <view class="card-body">
            <text class="card-usage">{{item.usageScenario || '素材库'}}</text>
            <text class="card-style">{{item.styleTag || '素材库'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
