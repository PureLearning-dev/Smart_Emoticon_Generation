.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f7f8fa;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.06);
}

.title {
  font-size: 36rpx;
  color: #333333;
  font-weight: 600;
}

.subtitle {
  margin-top: 8rpx;
  display: block;
  font-size: 24rpx;
  color: #666666;
}

.upload-panel {
  margin-top: 20rpx;
}

.choose-area {
  border-radius: 16rpx;
  background: #f7f8fa;
  border: 2rpx dashed #e0e4e8;
  padding: 48rpx 24rpx;
  text-align: center;
}

.choose-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.choose-tip {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}

.choose-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

.preview-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
}

.preview-img {
  width: 320rpx;
  height: 320rpx;
  border-radius: 16rpx;
  background: #f2f4f7;
}

.ghost-btn {
  width: 200rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
  font-size: 26rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.primary-btn {
  margin-top: 20rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #07c160;
  color: #ffffff;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.section-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.section-desc {
  font-size: 24rpx;
  color: #999999;
}

.state-wrap {
  padding: 32rpx 0;
  text-align: center;
}

.state-text {
  font-size: 24rpx;
  color: #999999;
}

.state-error {
  color: #ee0a24;
}

.waterfall {
  width: 100%;
}

.waterfall-inner {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.plaza-card {
  width: calc(50% - 10rpx);
  border-radius: 16rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(31, 35, 41, 0.08);
}

.card-image {
  width: 100%;
  display: block;
  background: #f0f0f0;
}

.card-body {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-usage {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-style {
  font-size: 22rpx;
  color: #FE2C55;
  background: rgba(254, 44, 85, 0.1);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  align-self: flex-start;
}

button::after {
  border: none;
}
