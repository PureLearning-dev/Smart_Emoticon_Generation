<view class="page">
  <view class="card head-card">
    <text class="title">我的生成</text>
    <text class="subtitle">管理并查看已生成图片</text>
  </view>

  <view class="card list-card">
    <view wx:if="{{loading}}" class="state-wrap">加载中...</view>
    <view wx:elif="{{!loading && list.length === 0}}" class="state-wrap">
      <text class="empty-text">暂无生成记录，去生成一张吧</text>
      <button type="default" class="empty-btn" bindtap="goCreateNew">去生成</button>
    </view>
    <view wx:else class="waterfall">
      <view class="waterfall-inner">
        <view
          class="plaza-card"
          wx:for="{{list}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onGoDetail"
        >
          <image
            class="card-image"
            src="{{item.generatedImageUrl}}"
            mode="widthFix"
          />
          <view class="card-body">
            <text class="card-usage">{{item.usageScenario || '日常'}}</text>
            <text class="card-style">{{item.styleTag || '日常'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="load-more-wrap">
      <button
        wx:if="{{hasMore && !loading && !loadingMore && list.length > 0}}"
        type="default"
        class="load-more-btn"
        bindtap="onLoadMore"
      >加载更多</button>
      <text wx:elif="{{loadingMore}}" class="load-more-text">加载中…</text>
      <text wx:elif="{{!hasMore && list.length > 0}}" class="load-more-text">没有更多了</text>
    </view>
  </view>

  <button class="primary-btn" bindtap="goCreateNew">去生成新图片</button>
</view>
