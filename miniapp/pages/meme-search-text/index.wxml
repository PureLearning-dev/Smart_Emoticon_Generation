<view class="page">
  <view class="card head-card">
    <text class="title">素材库文本搜图</text>
    <text class="subtitle">在爬虫/离线入库的素材库中按文字搜索表情包</text>
    <view class="search-panel">
      <input
        class="input"
        placeholder="请输入搜索关键词"
        placeholder-class="placeholder"
        value="{{keyword}}"
        bindinput="onInputKeyword"
      />
      <button type="default" class="primary-btn" bindtap="onSearch">开始搜索</button>
    </view>
  </view>

  <view class="card list-card">
    <view class="section-head">
      <text class="section-title">搜索结果</text>
      <text class="section-desc" wx:if="{{hasSearched && !loading}}">{{list.length}} 条</text>
    </view>

    <view wx:if="{{loading}}" class="state-wrap">
      <text class="state-text">加载中...</text>
    </view>
    <view wx:elif="{{error}}" class="state-wrap">
      <text class="state-text state-error">加载失败，请重试</text>
    </view>
    <view wx:elif="{{hasSearched && list.length === 0}}" class="state-wrap">
      <text class="state-text">暂无结果，试试其他关键词</text>
    </view>
    <view wx:elif="{{list.length > 0}}" class="waterfall">
      <view class="waterfall-inner">
        <view
          class="plaza-card"
          wx:for="{{list}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onGoDetail"
        >
          <image
            class="card-image"
            src="{{item.generatedImageUrl}}"
            mode="widthFix"
          />
          <view class="card-body">
            <text class="card-usage">{{item.usageScenario || '日常'}}</text>
            <text class="card-style">{{item.styleTag || '日常'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

