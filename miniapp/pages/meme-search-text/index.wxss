.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f7f8fa;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.06);
}

.head-card .title {
  font-size: 36rpx;
  color: #333333;
  font-weight: 600;
}

.head-card .subtitle {
  margin-top: 20rpx;
  display: block;
  font-size: 30rpx;
  color: #666666;
}

.list-card {
  flex: 1;
  min-height: 200rpx;
}

.search-panel {
  margin-top: 20rpx;
}

.input {
  height: 80rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e9edf3;
  background: #ffffff;
  box-sizing: border-box;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.placeholder {
  color: #999999;
  font-size: 24rpx;
}

.primary-btn {
  margin-top: 20rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #FE2C55;
  color: #ffffff;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.section-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.section-desc {
  font-size: 24rpx;
  color: #999999;
}

.state-wrap {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999999;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.state-error {
  color: #ee0a24;
}

.waterfall {
  width: 100%;
}

.waterfall-inner {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.plaza-card {
  width: calc(50% - 10rpx);
  border-radius: 16rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(31, 35, 41, 0.08);
}

.card-image {
  width: 100%;
  display: block;
  background: #f0f0f0;
}

.card-body {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-usage {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-style {
  font-size: 22rpx;
  color: #FE2C55;
  background: rgba(254, 44, 85, 0.1);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  align-self: flex-start;
}

button::after {
  border: none;
}

