.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #f3fff8 0%, #f7f8fa 360rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card,
.hero-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(31, 35, 41, 0.06);
  box-sizing: border-box;
}

.hero-card {
  overflow: hidden;
  position: relative;
}

.hero-card::after {
  content: "";
  position: absolute;
  top: -90rpx;
  right: -80rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(7, 193, 96, 0.12);
}

.hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: #07c160;
  font-weight: 600;
}

.title {
  display: block;
  margin-top: 8rpx;
  font-size: 40rpx;
  color: #222222;
  font-weight: 700;
  line-height: 1.3;
}

.hero-badge {
  position: relative;
  z-index: 1;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
}

.subtitle {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #666666;
}

.hero-body {
  position: relative;
  z-index: 1;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(7, 193, 96, 0.12);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
  background: #f7f8fa;
  border-radius: 20rpx;
  border: 2rpx solid #edf1f5;
  box-sizing: border-box;
}

.placeholder {
  color: #b6bcc5;
  font-size: 26rpx;
}

.search-btn {
  flex-shrink: 0;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #07c160, #31d983);
  box-shadow: 0 10rpx 22rpx rgba(7, 193, 96, 0.22);
}

.tags-scroll {
  width: 100%;
  white-space: nowrap;
}

.tags-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0 2rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #666666;
  background: #f7f8fa;
  border-radius: 999rpx;
  border: 2rpx solid #edf1f5;
}

.tag-item-active {
  color: #07c160;
  background: linear-gradient(180deg, rgba(7, 193, 96, 0.14), rgba(7, 193, 96, 0.06));
  border-color: rgba(7, 193, 96, 0.35);
  font-weight: 600;
}

.list-card {
  flex: 1;
  min-height: 200rpx;
}

.state-wrap {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999999;
}

.waterfall {
  width: 100%;
}

.waterfall-inner {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.plaza-card {
  width: calc(50% - 10rpx);
  border-radius: 20rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.08);
}

.card-image {
  width: 100%;
  display: block;
  background: #f0f0f0;
}

.card-body {
  padding: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-usage {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-style {
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  align-self: flex-start;
}

.load-more-wrap {
  padding: 32rpx 0 16rpx;
  text-align: center;
}

.load-more-btn {
  font-size: 28rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.12);
  border-radius: 16rpx;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
}

.load-more-text {
  font-size: 26rpx;
  color: #999999;
}

button::after {
  border: none;
}
