.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f7f8fa;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(31, 35, 41, 0.06);
}

.head-card .title {
  font-size: 36rpx;
  color: #333333;
  font-weight: 600;
}

.head-card .subtitle {
  margin-top: 20rpx;
  display: block;
  font-size: 30rpx;
  color: #666666;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
}

.placeholder {
  color: #999999;
}

.search-btn {
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: #FE2C55;
  border-radius: 12rpx;
}

.tags-scroll {
  width: 100%;
  white-space: nowrap;
}

.tags-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #666666;
  background: #f7f8fa;
  border-radius: 999rpx;
}

.tag-item-active {
  color: #ffffff;
  background: #FE2C55;
}

.list-card {
  flex: 1;
  min-height: 200rpx;
}

.state-wrap {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #999999;
}

.waterfall {
  width: 100%;
}

.waterfall-inner {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.plaza-card {
  width: calc(50% - 10rpx);
  border-radius: 16rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(31, 35, 41, 0.08);
}

.card-image {
  width: 100%;
  display: block;
  background: #f0f0f0;
}

.card-body {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-usage {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-style {
  font-size: 22rpx;
  color: #FE2C55;
  background: rgba(254, 44, 85, 0.1);
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  align-self: flex-start;
}

.load-more-wrap {
  padding: 32rpx 0 16rpx;
  text-align: center;
}

.load-more-btn {
  font-size: 28rpx;
  color: #FE2C55;
  background: rgba(254, 44, 85, 0.1);
  border-radius: 16rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.load-more-text {
  font-size: 26rpx;
  color: #999999;
}
