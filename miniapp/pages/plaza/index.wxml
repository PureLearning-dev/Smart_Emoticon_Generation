<view class="page">
  <view class="card">
    <text class="title">公共广场</text>
    <text class="subtitle">浏览平台公开推荐内容</text>
  </view>

  <view class="card">
    <view class="section-head">
      <text class="section-title">广场内容</text>
      <text class="section-desc">静态演示</text>
    </view>

    <view class="list">
      <view
        class="list-item"
        wx:for="{{plazaList}}"
        wx:key="id"
        data-item="{{item}}"
        bindtap="onTapPlazaItem"
      >
        <view class="top-row">
          <text class="item-title">{{item.title}}</text>
          <text class="item-type">{{item.type}}</text>
        </view>
        <text class="item-summary">{{item.summary}}</text>
        <text class="item-meta">{{item.author}}</text>
        <view class="action-btn">查看内容</view>
      </view>
    </view>
  </view>
</view>
