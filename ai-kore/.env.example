# 阿里云 OSS（图片存储）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=
OSS_PREFIX=meme-assets/

# Milvus（向量数据库）
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=meme_embeddings
MILVUS_VECTOR_DIM=512

# CLIP 模型
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=openai
CLIP_DEVICE=cpu

# OCR：baidu=百度通用文字识别 general_basic；paddle=本地 PaddleOCR 历史实现
OCR_ENGINE=baidu
BAIDU_OCR_APP_ID=
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_OCR_LANGUAGE_TYPE=CHN_ENG
# 仅 OCR_ENGINE=paddle 时生效
OCR_USE_ANGLE_CLS=true
OCR_LANG=ch
# OCR 前图片最长边上限（像素），超过则等比缩小；百度模式可降低上传体积
OCR_MAX_DIMENSION=1024
# 是否在爬虫入库管线中执行 OCR
OCR_ENABLED=false
# 单次 OCR 最长等待秒数；超时或异常时 ocr_text 写入 OCR_DEFAULT_TEXT（<=0 表示不限制）
OCR_TIMEOUT_SECONDS=45
# OCR 超时或识别失败时的默认文案（可为空）
OCR_DEFAULT_TEXT=

# smart_meter（主业务服务，管线完成后写入 meme_assets）
SMART_METER_BASE_URL=http://127.0.0.1:8080

# 阿里云百炼（图像生成 = DashScope 万相/千问，用于 /api/v1/image/generate；未配置时使用占位图）
# 北京地域（与百炼控制台北京区 API Key 配套）；新加坡/弗吉尼亚见 config 注释
BAILIAN_API_KEY=
# 万相（写实/艺术/参考图）：wan2.6-image；千问文生图（带文字的海报、排版）：qwen-image-2.0-pro
BAILIAN_IMAGE_MODEL=wan2.6-image
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# 仅当 BAILIAN_IMAGE_MODEL 为 qwen-image-* 时生效
BAILIAN_QWEN_SIZE=1024*1024
BAILIAN_QWEN_NEGATIVE_PROMPT=低分辨率，低画质，文字模糊，扭曲。

# 百炼文本大模型（生成 usage_scenario + style_tag；未配置或失败时降级为规则/默认「日常」）
BAILIAN_LLM_MODEL=qwen-turbo
BAILIAN_LLM_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
# 文生图与爬虫 VL 元数据共用；逗号分隔。扩充情绪类以减少「生气误判搞笑」，详见 app/core/style_tag_defaults.py
STYLE_TAG_LIST=搞笑,生气,吐槽,无语,震惊,敷衍,认同,阴阳怪气,撒娇,社死,治愈,励志,毒鸡汤,萌系,复古,简约,职场,情侣,朋友,节日,日常

# 视觉大模型（根据图片 URL 生成 title/ocr_text/description/usage_scenario/style_tag，用于爬虫入库管线）
# 复用 BAILIAN_API_KEY；北京地域；未配置时管线使用默认值
# DASHSCOPE_VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_VL_MODEL=qwen-vl-plus
# DASHSCOPE_VL_TIMEOUT=30
